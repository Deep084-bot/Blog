<!-- HEADER PARTIAL -->

<header class="page-header">
  <h1>Edit Post</h1>
</header>

<main class="container">

  <!-- FORM SHOULD BE PRE-FILLED WITH EXISTING DATA -->

  <form class="post-form" method="POST">

    <div class="form-group">
      <label>Title</label>

      <!-- VALUE SHOULD COME FROM POST DATA -->
      <input type="text" name="title">
    </div>

    <div class="form-group">
      <label>Content</label>

      <!-- CONTENT SHOULD COME FROM POST DATA -->
      <textarea name="content" rows="10"></textarea>
    </div>

    <button class="btn primary">Update Post</button>

  </form>

</main>

<!-- FOOTER PARTIAL -->