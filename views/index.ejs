<%- include("partials/header.ejs"); %>

<header class="hero">
  <h1>My Blog</h1>
  <p>Write. Share. Think.</p>
</header>

<main class="container">
  <section class="posts">

    <% for (let i = 0; i < posts.length; i++) { %>
      <% const element = posts[i]; %>

      <article class="post-card">
        <h2 class="post-title"><%= element.title %></h2>

        <p class="post-preview">
          <%= element.content.substring(0, 120) %>...
        </p>

        <p><strong><%= element.author %></strong></p>

        <div class="post-actions">
          <a class="btn read" href="/post/<%= element.id %>">Read More</a>

          <a class="btn edit" href="/edit/<%= element.id %>">Edit</a>

          <form action="/delete/<%= element.id %>" method="POST" style="display:inline;">
            <button class="btn delete">Delete</button>
          </form>
        </div>
      </article>

    <% } %>

  </section>
</main>

<%- include("partials/footer.ejs"); %>